<IfModule mod_rewrite.c>
    RewriteEngine On

    # 301 Redirects for removed/broken blog pages
    Redirect 301 /blogs/car-fluid-levels-beginners-guide/ /blogs/
    Redirect 301 /blogs/car-maintenance-fluids-levels/ /blogs/
    Redirect 301 /blogs/seasonal-car-care-guide/ /blogs/
    Redirect 301 /blogs/detailing-preserves-resale-value/ /blogs/
    Redirect 301 /blogs/eco-friendly-detailing-future/ /blogs/
    Redirect 301 /blogs/environmental-impact-traditional-detergents/ /blogs/
    Redirect 301 /blogs/essential-car-care-noida-dust/ /blogs/
    Redirect 301 /blogs/evolution-car-aesthetics-detailing/ /blogs/
    Redirect 301 /blogs/future-waterless-technology-global/ /blogs/
    Redirect 301 /blogs/glass-coating-benefits-hydrophobic/ /blogs/
    Redirect 301 /blogs/headlight-restoration-safety-visibility/ /blogs/
    Redirect 301 /blogs/how-to-increase-car-resale-value/ /blogs/
    Redirect 301 /blogs/importance-engine-bay-cleaning/ /blogs/
    Redirect 301 /blogs/maintaining-clean-car-mussoorie-dust/ /blogs/
    Redirect 301 /blogs/mobile-detailing-overtaking-static-workshops/ /blogs/
    Redirect 301 /blogs/navigating-dehradun-monsoons-car-tips/ /blogs/
    Redirect 301 /blogs/new-trends-hydrophobic-paint-protection/ /blogs/
    Redirect 301 /blogs/odor-removal-secrets-persistent-smells/ /blogs/
    Redirect 301 /blogs/paint-correction-vs-polishing/ /blogs/
    Redirect 301 /blogs/pro-car-waxing-tips/ /blogs/
    Redirect 301 /blogs/pro-interior-detailing-checklist/ /blogs/
    Redirect 301 /blogs/reasons-doorstep-car-cleaning-dehradun/ /blogs/
    Redirect 301 /blogs/rise-doorstep-services-automotive-sector/ /blogs/
    Redirect 301 /blogs/steam-cleaning-vs-traditional-wash/ /blogs/
    Redirect 301 /blogs/summer-maintenance-tips-protection/ /blogs/
    Redirect 301 /blogs/top-road-trip-destinations-near-dehradun/ /blogs/
    Redirect 301 /blogs/waterless-wash-scratch-safety/ /blogs/
    Redirect 301 /blogs/waterless-wash-water-savings-dehradun/ /blogs/
    Redirect 301 /blogs/why-sustainable-car-care-efficient/ /blogs/
    Redirect 301 /blogs/winter-car-care-cold-climates/ /blogs/
    
    # 301 Redirects for city pages that were accidentally in /blogs/
    Redirect 301 /blogs/doorstep-car-cleaning-service-noida/ /doorstep-car-washing-service-in-noida/
    Redirect 301 /blogs/doorstep-car-washing-service-in-dehradun/ /doorstep-car-washing-service-in-dehradun/

    # 301 Redirects for why-carmaa-is-becoming-dehradun-choice blog slug variants
    Redirect 301 /why-carmaa-is-becoming-dehradun-choice /blogs/why-carmaa-is-becoming-dehradun-choice/
    Redirect 301 /blogs/why-carmaa-is-becoming-dehradun's-choice/ /blogs/why-carmaa-is-becoming-dehradun-choice/

    # 410 Gone for discontinued services/pages and GSC 404 errors requested by user
    RedirectMatch 410 "(?i)^/blogs/doorstep-car-washing-service-in-meerut/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-roorkee/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-mussoorie/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-haldwani/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-meerut/?$"
    RedirectMatch 410 "(?i)^/blogs/doorstep-car-washing-service-in-gurgaon/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-delhi/blogs/?$"
    RedirectMatch 410 "(?i)^/best-car-mechanics-in-dehradun/blogs/?$"
    RedirectMatch 410 "(?i)^/blogs/why-carmaa-is-becoming-dehradun's-choice/blogs/?$"
    RedirectMatch 410 "(?i)^/blogs/dry-cleaning-services-at-your-doorstep/blogs/?$"
    RedirectMatch 410 "(?i)^/blogs/about/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-aligarh/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-rishikesh/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-haridwar/?$"
    RedirectMatch 410 "(?i)^/blogs/why-carmaa-is-becoming-dehradun&apos;s-choice/?$"
    RedirectMatch 410 "(?i)^/why-carmaa-is-becoming-dehradun's-choice/?$"
    RedirectMatch 410 "(?i)^/doorstep-car-washing-service-in-haldwani/blogs/?$"

    # 410 Gone for previously discontinued services/pages
    Redirect 410 /doorstep-car-decoration-service-in-dehradun/
    Redirect 410 /blogs/doorstep-car-decor-in-dehradun/
    Redirect 410 /exterior-car-cleaning-washing/

    # Enforce HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Fix trailing slash — redirect all non-file, non-directory 
    # URLs without trailing slash to add trailing slash
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !/$
    RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

    # Block direct index.html access — redirect to clean URL
    RewriteCond %{THE_REQUEST} /index\.html
    RewriteRule ^(.*)index\.html$ /$1 [R=301,L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Video
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/mpeg "access plus 1 year"
    
    # CSS, JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # Others
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Security Headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|avif|avifs|svg|ico|mp4|woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Never cache HTML to ensure cache-busted URLs are fetched
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>

